DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_local_password_here
DB_NAME=study_room

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_local_password_here
MYSQL_DATABASE=study_room
MYSQL_CHARSET=utf8mb4

# Stream startup settings. Leave STREAM_NAME/STREAM_URL empty to load
# camera.stream_url from the database for STREAM_CAMERA_ID.
STREAM_CAMERA_ID=5
STREAM_NAME=
STREAM_URL=
STREAM_LOCAL_CAMERA=

# DingTalk robot settings. PUBLIC_BASE_URL must be an HTTP/HTTPS backend URL,
# not an RTMP stream URL. It is used by the "confirm" button in ActionCard.
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
DINGTALK_LEADER_WEBHOOK=
DINGTALK_LEADER_SECRET=
PUBLIC_BASE_URL=http://127.0.0.1:5000
ESCALATE_TIMEOUT=180

# Fire/smoke detection. The default weights path resolves under backend/model_weights.
# Legacy YOLOv5 checkpoints from fire-smoke-detect-yolov4-master need the bundled
# YOLOv5 source directory for unpickling and inference compatibility.
FIRE_SMOKE_WEIGHTS=fire_smoke.pt
FIRE_SMOKE_LEGACY_YOLOV5_DIR=fire-smoke-detect-yolov4-master/yolov5
FIRE_SMOKE_MODEL_LOADER=legacy
FIRE_SMOKE_IMG_SIZE=640
FIRE_SMOKE_DETECT_CONF=0.25
FIRE_SMOKE_IOU=0.45
FIRE_SMOKE_DEVICE=cpu
