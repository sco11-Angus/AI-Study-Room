# ==========================================
# 智慧自习室 AI 管家 — 环境变量模板
# 复制为 .env 后修改实际值
# ==========================================

# --- 流处理与调度 (§3) ---
SKIP_N=5                          # 每 N 帧推理一次

# --- RTMP 服务器 ---
RTMP_SERVER=49.233.71.82
RTMP_PORT=9090

# --- 疲劳检测阈值 (§4.3) ---
EAR_THRESH=0.2                    # 闭眼 EAR 阈值
EAR_DURATION=2.0                  # 闭眼持续秒数
MAR_THRESH=0.6                    # 打哈欠 MAR 阈值

# --- 烟火检测 (§6.2) ---
FIRE_WINDOW=30                    # 连续帧滑动窗口
FIRE_CONF=0.45                    # 平均置信度阈值

# --- 告警升级 (§7.4) ---
ESCALATE_TIMEOUT=180              # 升级超时(秒)

# --- 钉钉 Webhook (§7.4) ---
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_token_here

# --- 数据库 (§8) ---
DATABASE_URI=sqlite:///study_room.db

# --- 模型权重 / 抓拍路径 ---
MODEL_DIR=model_weights
SNAPSHOT_DIR=snapshots

# --- 活体检测 (Face Anti-Spoofing) ---
LIVENESS_ENABLED=true             # 是否启用活体检测
LIVENESS_THRESHOLD=0.5            # 活体融合分阈值 [0,1]
LIVENESS_HISTORY_SIZE=30          # 历史帧缓存数量 (约1秒@30fps)
LIVENESS_EAR_BLINK_THRESH=0.25   # 眨眼EAR低阈值
